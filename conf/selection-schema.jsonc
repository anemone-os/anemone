{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Anemone Build Selection",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "preset": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Canonical BuildPreset filename slug."
        }
    },
    "required": [
        "preset"
    ]
}
