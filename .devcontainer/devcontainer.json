// TODO: kvm in docker.
{
    "name": "anemone-dev",
    "build": {
        "context": "..",
        "dockerfile": "../Dockerfile",
        "options": [
            "--platform=linux/amd64",
            "--network=host"
        ],
        "target": "fin_dev",
        "args": {
            "QEMU_VERSION": "10.2.1",
            "GNU_VERSION": "2026.01.09"
        }
    },
    "remoteUser": "user",
    "updateRemoteUserUID": true,
    "customizations": {
        "vscode": {
            "extensions": [
                "donjayamanne.githistory",
                "github.copilot-chat",
                "ms-vscode.hexeditor",
                "ms-python.python",
                "nefrob.vscode-just-syntax",
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml"
            ],
            "settings": {}
        }
    },
    "mounts": [
        "source=cargo-cache,target=/usr/local/cargo/registry,type=volume"
    ],
    "runArgs": [
        "--network=host"
    ]
}